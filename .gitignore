# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all except the example (which only has placeholders)
.env*
!.env.example

# vercel
.vercel

# deploy artifacts (cPanel/standalone builds — not needed for Vercel)
*.zip
server.js

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
