# ─── BUILD-TIME (GitHub Secrets) ─────────────────────────────────────────────
# These are NEXT_PUBLIC_* variables baked into the bundle during `npm run build`.
# They cannot be changed after the build without a full redeploy.
# Add each one as a GitHub Secret in Settings → Secrets and variables → Actions.

# URL pública do site (usado no QR code da PWA)
NEXT_PUBLIC_SITE_URL=https://pontofly.pt

# Google Analytics 4 — deixar vazio para desativar
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Shopify Storefront API (token público — NÃO usar o token de Admin)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=a-tua-loja.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── RUNTIME (cPanel → Node.js App → Environment Variables) ──────────────────
# Estas variáveis são lidas em runtime pelo servidor Node.js.
# Nunca entram no bundle; devem ser configuradas APENAS no painel do cPanel.
# (Node.js App → Edit → Environment Variables)

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL=geral@pontofly.pt
